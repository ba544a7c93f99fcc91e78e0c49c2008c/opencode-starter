{
  "$schema": "https://opencode.ai/config.json",

  "model": "anthropic/claude-sonnet-4-6",
  "small_model": "anthropic/claude-haiku-4-5-20251001",

  "instructions": ["AGENTS.md"],

  "permission": {
    "bash": {
      "rm -rf*":           "deny",
      "git reset --hard*": "ask",
      "git push --force*": "deny",
      "git push*":         "ask",
      "git commit*":       "ask",
      "git add*":          "allow",
      "git diff*":         "allow",
      "git log*":          "allow",
      "git status*":       "allow",
      "make *":            "allow",
      "sh tests/*":        "allow",
      "sh .agent/*":       "allow"
    }
  },

  "autoupdate": "notify",
  "share": "manual"
}
